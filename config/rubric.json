  "bonus_rules": [
    {"condition": "confidence >= 0.7", "axis": "reliability", "bonus": 2},
    {"condition": "evidence_count >= 5", "axis": "evidence_quality", "bonus": 2},
    {"condition": "evidence_count >= 10", "axis": "evidence_quality", "bonus": 1},
    {"condition": "recommendations_count >= 3", "axis": "actionability", "bonus": 2},
    {"condition": "recommendations_count >= 10", "axis": "impact", "bonus": 2},
