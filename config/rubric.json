    {"condition": "verified_claim_ratio < 0.50", "axis": "citation_fidelity", "bonus": -3},
    {"condition": "verified_claim_ratio < 0.30", "axis": "citation_fidelity", "bonus": -5},
    {"condition": "unsupported_critical_claim_count > 0", "axis": "citation_fidelity", "bonus": -3},
    {"condition": "supported_claim_count >= 5", "axis": "citation_fidelity", "bonus": 1}
